# Server
PORT=3000
NODE_ENV=development

# Database
DB_HOST=localhost
DB_PORT=5432
DB_NAME=learnavo
DB_USER=postgres
DB_PASSWORD=postgres

# JWT
JWT_SECRET=learnavo-jwt-secret-change-in-production-2026
JWT_REFRESH_SECRET=learnavo-refresh-secret-change-in-production-2026
JWT_EXPIRES_IN=24h
JWT_REFRESH_EXPIRES_IN=7d

# QR
QR_ROTATION_SECONDS=30
QR_HMAC_SECRET=learnavo-qr-hmac-master-secret-2026

# BLE
BLE_RSSI_THRESHOLD=-75
BLE_READING_COUNT=10
BLE_PROXIMITY_METERS=8

# Student Module HMAC
HMAC_SECRET=learnavo-hmac-token-secret-2026
